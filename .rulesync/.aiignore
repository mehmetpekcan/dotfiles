# Rulesync Ignore File
# Files and directories to exclude from rulesync processing

# Dependencies
node_modules/
**/node_modules/

# Build outputs
.next/
out/
build/
dist/
.turbo/
.sanity/

# Generated agent folders (managed by rulesync)
.claude/
.cursor/
.github/prompts/
.github/agents/
.github/instructions/
.codex/
.gemini/
.serena/
.agents/

# Environment files
.env
.env.*
!.env.example

# Testing
coverage/
.nyc_output/
**/cypress/videos/
**/cypress/screenshots/
**/cypress/downloads/

# System files
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo
.tsbuildinfo
tsconfig.tsbuildinfo

# IDE
.vscode/
.idea/

# Vercel
.vercel/

# Temporary files
*.tmp
*.temp
